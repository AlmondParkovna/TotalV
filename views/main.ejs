                                <td><%= item.name %></td>
                                <td><%= item.price %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <div class="container">
                <h2 class="title">Почему вы должны сдать лом/вторсырье или заказать контейнер у нас</h2>
